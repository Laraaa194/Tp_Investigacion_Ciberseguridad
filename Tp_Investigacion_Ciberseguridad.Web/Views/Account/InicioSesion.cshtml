@using Tp_Investigacion_Ciberseguridad.Web.Models.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/account.css" rel="stylesheet" />

<div class="gs-wrap">
    <div class="gs-card">

        <h1 class="gs-title">Bienvenido de vuelta</h1>
        <p class="gs-subtitle">Ingresá tus credenciales para acceder a tu cuenta.</p>

        <form asp-action="IniciarSesion" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="gs-validation-error mb-3"></div>

            
            <div class="mb-3">
                <label asp-for="Email" class="gs-field-label">Correo electrónico</label>
                <input asp-for="Email"
                       class="gs-input"
                       placeholder="nombre@ejemplo.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="gs-validation-error"></span>
            </div>

            
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Password" class="gs-field-label mb-0">Contraseña</label>
                    <a asp-action="ForgotPassword"
                           class="gs-login-hint" style="margin-top:0; font-size:0.78rem">
                        ¿Olvidaste?
                    </a>
                </div>
                <div class="gs-pass-wrap">
                    <input asp-for="Password"
                           id="passwordInput"
                           type="password"
                           class="gs-input"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                    <button type="button"
                            class="gs-pass-toggle"
                            onclick="togglePassword()"
                            aria-label="Mostrar u ocultar contraseña">
                        <i class="bi bi-eye" id="passIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="gs-validation-error"></span>
            </div>

            
            <button type="submit" class="gs-btn">Acceder a la cuenta</button>

        </form>

        
        <div class="gs-divider">
            <div class="gs-divider-line"></div>
            <span class="gs-divider-text">o continuá con</span>
            <div class="gs-divider-line"></div>
        </div>

        
        <a href="/signin-google" class="gs-google-btn">
            <svg width="18" height="18" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38
                30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72
                17.74 9.5 24 9.5z" />
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94
                c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18
                7.09-10.36 7.09-17.65z" />
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59
                l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92
                7.54 2.56 10.78l7.97-6.19z" />
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6
                c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91
                l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                <path fill="none" d="M0 0h48v48H0z" />
            </svg>
            Continuar con Google
        </a>

        
        <p class="gs-login-hint">
            ¿No tenés cuenta?
            <a asp-controller="Account" asp-action="Registro">Registrate</a>
        </p>

    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
   }

}
