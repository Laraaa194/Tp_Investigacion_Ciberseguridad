@using Tp_Investigacion_Ciberseguridad.Web.Models.ViewModels
@using Microsoft.AspNetCore.Identity

@inject SignInManager<Tp_Investigacion_Ciberseguridad.Core.Entidades.Usuario> SignInManager

@model RegistroViewModel

@{
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    ViewData["Title"] = "Crear cuenta";
    var externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
    var googleProvider = externalLogins.FirstOrDefault(p => p.Name == "Google");
}
<link href="~/css/account.css" rel="stylesheet" />



<div class="gs-wrap">
    <div style="width: 100%; max-width: 480px;">
        <h1 class="gs-title">Crear una cuenta</h1>
        <p class="gs-subtitle">Completá tus datos para empezar.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="gs-validation-error mb-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-1">@error.ErrorMessage</p>
                }
            </div>
        }
        <div class="gs-card">
            <form asp-action="Registrar" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="gs-validation-error mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="Nombre" class="gs-field-label"></label>
                        <input asp-for="Nombre" class="gs-input"
                               placeholder="Juan" />
                        <span asp-validation-for="Nombre"
                              class="gs-validation-error"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Apellido" class="gs-field-label"></label>
                        <input asp-for="Apellido" class="gs-input"
                               placeholder="Perez" />
                        <span asp-validation-for="Apellido"
                              class="gs-validation-error"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="gs-field-label"></label>
                    <input asp-for="Email" class="gs-input"
                           placeholder="juan@dominio.com" />
                    <span asp-validation-for="Email"
                          class="gs-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserName" class="gs-field-label"></label>
                    <input asp-for="UserName" class="gs-input"
                           placeholder="juan_1" />
                    <span asp-validation-for="UserName"
                          class="gs-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaNacimiento" class="gs-field-label"></label>
                    <input asp-for="FechaNacimiento" type="date"
                           class="gs-input" />
                    <span asp-validation-for="FechaNacimiento"
                          class="gs-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="gs-field-label"></label>
                    <div class="gs-pass-wrap">
                        <input asp-for="Password" type="password"
                               id="passwordInput" class="gs-input"
                               placeholder="••••••••" />
                        <button type="button" class="gs-pass-toggle"
                                onclick="togglePassword()"
                                aria-label="Mostrar u ocultar contraseña">
                            <i class="bi bi-eye" id="passIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password"
                          class="gs-validation-error"></span>
                </div>

                <button type="submit" class="gs-btn">
                    Registrarse
                </button>

                <div class="gs-divider">
                    <div class="gs-divider-line"></div>
                    <span class="gs-divider-text">o</span>
                    <div class="gs-divider-line"></div>
                </div>

                
            </form>

            @if (googleProvider != null)
            {
                <form asp-controller="Account" asp-action="LoginExterno" method="post">

                    <button type="submit" name="proveedor" value="@googleProvider.Name" class="gs-google-btn" title="Ingresar con Google">
                        <svg width="18" height="18" viewBox="0 0 48 48">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94 c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59 l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6 c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91 l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                            <path fill="none" d="M0 0h48v48H0z" />
                        </svg>
                        Continuar con Google
                    </button>
                </form>
            }
            else
            {
                <div class="text-danger">
                    ⚠️ Error: El proveedor "Google" no está activo. Revisá las credenciales en appsettings.
                </div>
            }

        </div>

        <p class="gs-login-hint">
            ¿Ya tenés cuenta?
            <a asp-controller="Account" asp-action="InicioSesion">Iniciá sesión</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

}