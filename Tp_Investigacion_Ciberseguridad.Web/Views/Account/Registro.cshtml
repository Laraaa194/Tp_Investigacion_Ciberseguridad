@using Tp_Investigacion_Ciberseguridad.Web.Models.ViewModels
@model RegistroViewModel

@{
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    ViewData["Title"] = "Crear cuenta";
}
<link href="~/css/account.css" rel="stylesheet" />



<div class="gs-wrap">
    <div style="width: 100%; max-width: 480px;">
        <h1 class="gs-title">Crear una cuenta</h1>
        <p class="gs-subtitle">Completá tus datos para empezar.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="gs-validation-error mb-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-1">@error.ErrorMessage</p>
                }
            </div>
        }
        <div class="gs-card">
            <form asp-action="Registrar" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="gs-validation-error mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="Nombre" class="gs-field-label"></label>
                        <input asp-for="Nombre" class="gs-input"
                               placeholder="Ada" />
                        <span asp-validation-for="Nombre"
                              class="gs-validation-error"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Apellido" class="gs-field-label"></label>
                        <input asp-for="Apellido" class="gs-input"
                               placeholder="Lovelace" />
                        <span asp-validation-for="Apellido"
                              class="gs-validation-error"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="gs-field-label"></label>
                    <input asp-for="Email" class="gs-input"
                           placeholder="nombre@dominio.com" />
                    <span asp-validation-for="Email"
                          class="gs-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserName" class="gs-field-label"></label>
                    <input asp-for="UserName" class="gs-input"
                           placeholder="ada_lovelace" />
                    <span asp-validation-for="UserName"
                          class="gs-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaNacimiento" class="gs-field-label"></label>
                    <input asp-for="FechaNacimiento" type="date"
                           class="gs-input" />
                    <span asp-validation-for="FechaNacimiento"
                          class="gs-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="gs-field-label"></label>
                    <div class="gs-pass-wrap">
                        <input asp-for="Password" type="password"
                               id="passwordInput" class="gs-input"
                               placeholder="••••••••" />
                        <button type="button" class="gs-pass-toggle"
                                onclick="togglePassword()"
                                aria-label="Mostrar u ocultar contraseña">
                            <i class="bi bi-eye" id="passIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password"
                          class="gs-validation-error"></span>
                </div>

                <button type="submit" class="gs-btn">
                    Registrarse
                </button>

                <div class="gs-divider">
                    <div class="gs-divider-line"></div>
                    <span class="gs-divider-text">o</span>
                    <div class="gs-divider-line"></div>
                </div>

                <a asp-controller="Account" asp-action="GoogleLogin"
                       class="gs-google-btn">
                    <svg width="18" height="18" viewBox="0 0 18 18"
                         xmlns="http://www.w3.org/2000/svg">
                        <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4" />
                        <path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853" />
                        <path d="M3.964 10.706A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.038l3.007-2.332z" fill="#FBBC05" />
                        <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335" />
                    </svg>
                    Registrarse con Google
                </a>
            </form>
        </div>

        <p class="gs-login-hint">
            ¿Ya tenés cuenta?
            <a asp-controller="Account" asp-action="InicioSesion">Iniciá sesión</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

}