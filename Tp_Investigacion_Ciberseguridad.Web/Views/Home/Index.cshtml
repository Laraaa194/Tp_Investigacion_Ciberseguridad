@{
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="gs-hero">

    <div class="container-fluid px-4 h-100 d-flex align-items-center">
        <div class="gs-hero-content">
            <h1 class="gs-hero-title">
                Bienvenido a <br />
                <span class="gs-accent">Gestión Segura</span>
            </h1>
            <p class="gs-hero-subtitle">
                Iniciá sesión para gestionar tu perfil,
                desde un entorno seguro y centralizado.
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-controller="Account" asp-action="Registro"
                       class="btn gs-btn-primary">
                    Crear cuenta &rarr;
                </a>
                <a asp-controller="Account" asp-action="InicioSesion"
                       class="btn gs-btn-secondary">
                    Iniciar sesión
                </a>
            </div>
        </div>
    </div>
</section>