@{
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_LayoutLogueado.cshtml";
}

@section Styles{

    <link href="~/css/inicio-admin.css" rel="stylesheet" />
}

@if (User.IsInRole("Admin")){


<div class="page-header">
    <h1>Bienvenido, Administrador</h1>
    <p>Resumen general del sistema · <span id="fecha"></span></p>
</div>


<div class="kpi-grid">
    <div class="kpi">
        <div class="kpi-label">Total de usuarios</div>
        <div class="kpi-value">248</div>
        <div class="kpi-delta">▲ 12 este mes</div>
    </div>
    <div class="kpi">
        <div class="kpi-label">Activos (7 días)</div>
        <div class="kpi-value">187</div>
        <div class="kpi-delta">▲ 5.4%</div>
    </div>
    <div class="kpi">
        <div class="kpi-label">Nuevos esta semana</div>
        <div class="kpi-value">14</div>
        <div class="kpi-delta down">▼ 2 vs semana anterior</div>
    </div>
    <div class="kpi">
        <div class="kpi-label">Inactivos +30 días</div>
        <div class="kpi-value">23</div>
        <div class="kpi-delta down">Requieren revisión</div>
    </div>
</div>

<!-- Acciones rápidas -->
<div class="card" style="margin-bottom:24px;">
    <h2>Acciones rápidas</h2>
    <div class="actions">
        <button class="btn">+ Crear usuario</button>
        <button class="btn outline">Ver todos los usuarios</button>
        <button class="btn outline">Asignar roles</button>
        <button class="btn outline">Exportar reporte</button>
    </div>
</div>





<div class="row">
    <div class="card">
        <h2>Últimos usuarios registrados <a href="#">Ver todos</a></h2>
        <table>
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Tiempo en la app</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="avatar">M</span> María González</td>
                    <td><span class="badge badge-admin">Admin</span></td>
                    <td><span class="badge badge-active">Activo</span></td>
                    <td>2 días</td>
                </tr>
                <tr>
                    <td><span class="avatar">J</span> Juan Pérez</td>
                    <td><span class="badge badge-editor">Editor</span></td>
                    <td><span class="badge badge-active">Activo</span></td>
                    <td>5 días</td>
                </tr>
                <tr>
                    <td><span class="avatar">L</span> Lucía Romero</td>
                    <td><span class="badge badge-user">Usuario</span></td>
                    <td><span class="badge badge-inactive">Inactivo</span></td>
                    <td>1 semana</td>
                </tr>
                <tr>
                    <td><span class="avatar">C</span> Carlos Díaz</td>
                    <td><span class="badge badge-user">Usuario</span></td>
                    <td><span class="badge badge-active">Activo</span></td>
                    <td>3 semanas</td>
                </tr>
                <tr>
                    <td><span class="avatar">S</span> Sofía Martínez</td>
                    <td><span class="badge badge-editor">Editor</span></td>
                    <td><span class="badge badge-active">Activo</span></td>
                    <td>1 mes</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="card">
        <h2>Actividad reciente</h2>
        <div class="log-item">
            <div class="log-icon">+</div>
            <div class="log-text">
                <b>Admin</b> creó al usuario <b>María González</b>
                <small>hace 10 min</small>
            </div>
        </div>
        <div class="log-item">
            <div class="log-icon">↻</div>
            <div class="log-text">
                <b>Admin</b> cambió el rol de <b>Juan Pérez</b> a Editor
                <small>hace 1 hora</small>
            </div>
        </div>
        <div class="log-item">
            <div class="log-icon">×</div>
            <div class="log-text">
                <b>Admin</b> eliminó al usuario <b>Pedro López</b>
                <small>hace 3 horas</small>
            </div>
        </div>
        <div class="log-item">
            <div class="log-icon">→</div>
            <div class="log-text">
                <b>Sofía Martínez</b> inició sesión
                <small>hace 5 horas</small>
            </div>
        </div>
    </div>
</div>


<div class="card">
    <h2>Alertas de seguridad</h2>
    <div class="alert warn">
        <div>
            <b>3 intentos de login fallidos</b>
            Cuenta: carlos.diaz@empresa.com — últimos 15 min
        </div>
    </div>
    <div class="alert danger">
        <div>
            <b>Cuenta bloqueada temporalmente</b>
            Usuario: pedro.lopez — superó el límite de intentos
        </div>
    </div>
    <div class="alert warn">
        <div>
            <b>23 usuarios inactivos hace más de 30 días</b>
            Considerá depurarlos o enviar un recordatorio.
        </div>
    </div>
</div>

}

@section Scripts {
    <script src="~/js/inicio-admin.js"></script>
}