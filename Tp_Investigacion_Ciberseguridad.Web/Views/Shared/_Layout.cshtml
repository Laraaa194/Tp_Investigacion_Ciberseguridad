_Layout.cshtml
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión Segura</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/css/gestion-segura.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-dark gs-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21
                    17.25 21 12V7L12 2z"
                          stroke="#00bcd4" stroke-width="2"
                          stroke-linejoin="round" fill="none" />
                    <circle cx="12" cy="12" r="2.5" fill="#00bcd4" />
                </svg>
                <span class="fw-semibold">Gestión Segura</span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <a asp-controller="Account" asp-action="InicioSesion"
                       class="btn btn-link text-white text-decoration-none">
                    Iniciar sesión
                </a>
                <a asp-controller="Account" asp-action="Registro"
                       class="btn gs-btn-register">
                    Registrarse
                </a>
            </div>
        </div>
    </nav>

    <div class="gs-page-bg">
        <div class="gs-page-overlay"></div>
        <main>
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/account.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

   
</body>
</html>