@{
    Layout = "~/Views/Shared/_LayoutBase.cshtml";
}

@section Styles {
    <link href="~/css/logueado.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
}


<header class="gs-topbar">
    <div class="d-flex align-items-center gap-2">
        <button class="gs-sidebar-toggle" id="sidebarToggle" aria-label="Contraer menú">
            <i class="bi bi-list"></i>
        </button>
        <a asp-controller="Inicio" asp-action="Inicio" class="gs-topbar-brand d-flex align-items-center gap-2">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z"
                      stroke="#00dcb4" stroke-width="2" stroke-linejoin="round" fill="none" />
                <circle cx="12" cy="12" r="2.5" fill="#00dcb4" />
            </svg>
            <span class="fw-semibold">Gestión Segura</span>
        </a>
    </div>

    <div class="d-flex align-items-center gap-3">
        <div class="gs-topbar-user">
            <div class="gs-avatar">
                @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
            </div>
            <div class="gs-topbar-user-info d-none d-md-block">
                
                <span class="gs-topbar-role">
                    @(User.IsInRole("Admin") ? "Administrador" : "")
                </span>
            </div>
        </div>
    </div>
</header>

<div class="gs-app-shell">

    
    <aside class="gs-sidebar" id="sidebar">

        <nav class="gs-sidebar-nav">

            
           
            
            @if (!User.IsInRole("Admin"))
            {
                <a asp-controller="Inicio" asp-action="Inicio"
                   class="gs-nav-item" title="Inicio">
                    <i class="bi bi-house-door"></i>
                    <span class="gs-nav-label">Inicio</span>
                </a>

                <a asp-controller="Perfil" asp-action="Perfil"
                       class="gs-nav-item" title="Perfil">
                    <i class="bi bi-person"></i>
                    <span class="gs-nav-label">Perfil</span>
                </a>
            }

           
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Inicio"
                   class="gs-nav-item" title="Inicio">
                    <i class="bi bi-house-door"></i>
                    <span class="gs-nav-label">Inicio</span>
                </a>

                <a asp-controller="Admin" asp-action="PanelAdmin"
                       class="gs-nav-item" title="Panel de Administración">
                    <i class="bi bi-gear"></i>
                    <span class="gs-nav-label">Panel de Administración</span>
                </a>
            }

        </nav>

       
        <div class="gs-sidebar-footer">
            <form asp-controller="Account" asp-action="CerrarSesion" method="post">
                <button type="submit" class="gs-nav-item gs-nav-item--danger" title="Cerrar sesión">
                    <i class="bi bi-box-arrow-left"></i>
                    <span class="gs-nav-label">Salir</span>
                </button>
            </form>
        </div>

    </aside>

    <div class="gs-page-bg">
        <div class="gs-page-overlay"></div>
            <main class="gs-main-content">
                @RenderBody()
            </main>
    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/sidebar.js"></script>
}


